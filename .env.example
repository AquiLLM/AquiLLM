# Core Settings
SECRET_KEY=django-insecure-change-this-in-production
DJANGO_DEBUG=0
PORT=8080
HOST_NAME=localhost
# For HTTPS behind nginx (Compose): add web,nginx and your public hostname.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,https://localhost

# Database Configuration
POSTGRES_USER=aquillm
POSTGRES_PASSWORD=aquillm
POSTGRES_NAME=aquillm
POSTGRES_HOST=db

# Storage Configuration (MinIO/S3)
STORAGE_HOST=storage:9000
STORAGE_ACCESS_KEY=dev
STORAGE_SECRET_KEY=rickbailey

# Authentication
GOOGLE_OAUTH2_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH2_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAIL_DOMAINS=example.edu,example.org
ALLOWED_EMAIL_ADDRESSES=your@email.com,another@email.com
WM_EMAIL=admin@example.com

# LLM Configuration - At least one API key is required
LLM_CHOICE=QWEN3_30B  # Options: CLAUDE, OPENAI, BEDROCK-CLAUDE, GEMMA3, LLAMA3.2, GPT-OSS, QWEN3_30B
ANTHROPIC_API_KEY=your-claude-api-key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
COHERE_KEY=your-cohere-api-key
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen/Qwen2.5-32B-Instruct
VLLM_SERVED_MODEL_NAME=qwen3.5:27b-q8_0
# Optional: set to an absolute host path to persist model/cache files on a larger disk.
# Example: /media/volume/AquiLLM-Datat/vllm-cache
VLLM_CACHE_PATH=vllm_data
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.8
VLLM_MAX_MODEL_LEN=32768
# Self-hosted image: deploy/docker/vllm/Dockerfile pins vllm/vllm-openai:v0.17.1 until v0.18.x stabilizes (Whisper + bitsandbytes 4-bit).
# On v0.17.x, optional KV headroom: add --swap-space <GiB> below. v0.18+ may use --cpu-offload-gb; confirm flags with your image's serve --help.
# Optional extra args for primary vLLM service only (e.g. --reasoning-parser qwen3 for Qwen3 chat models).
# Satellite vLLM services map VLLM_EXTRA_ARGS from OCR_VLLM_EXTRA_ARGS, TRANSCRIBE_*, MEM0_EMBED_*, APP_RERANK_* via Compose; pass this file into substitution:
#   docker compose --env-file .env -f deploy/compose/base.yml …
# If you omit --env-file, substitution may be empty and /vllm_start.sh still fills from *_VLLM_EXTRA_ARGS in the container env_file.
VLLM_EXTRA_ARGS=
VLLM_TRUST_REMOTE_CODE=0
# Optional tokenizer override (often needed for GGUF checkpoints)
VLLM_TOKENIZER=

# App embeddings (RAG / tools; self-hosted vLLM OpenAI-compatible /v1/embeddings)
APP_EMBED_BASE_URL=http://vllm_embed:8000/v1
APP_EMBED_API_KEY=EMPTY
APP_EMBED_MODEL=Qwen/Qwen3-VL-Embedding-2B
# Must match the model output width (wrong value breaks retrieval shaping)
APP_EMBED_DIMS=1024
APP_EMBED_ALLOW_DIMENSIONS_OVERRIDE=0

# Dedicated OCR vLLM service (vllm_ocr)
OCR_VLLM_MODEL=Qwen/Qwen3.5-4B
OCR_VLLM_SERVED_MODEL_NAME=qwen3.5-ocr
OCR_VLLM_TOKENIZER=Qwen/Qwen3.5-4B
OCR_VLLM_TENSOR_PARALLEL_SIZE=1
# vLLM fraction of total GPU memory for OCR sidecar. Raise if you still hit startup/runtime cache pressure.
OCR_VLLM_GPU_MEMORY_UTILIZATION=0.15
OCR_VLLM_MAX_MODEL_LEN=4096
OCR_VLLM_TRUST_REMOTE_CODE=1
OCR_VLLM_EXTRA_ARGS="--kv-cache-dtype fp8 --compilation-config '{\"cudagraph_mode\":\"PIECEWISE\"}' --quantization bitsandbytes --load-format bitsandbytes --dtype float16 --model-loader-extra-config '{\"load_in_4bit\":true,\"bnb_4bit_compute_dtype\":\"float16\",\"bnb_4bit_quant_type\":\"nf4\",\"bnb_4bit_use_double_quant\":true}'"

# Dedicated transcription vLLM service (vllm_transcribe)
# Dockerfile pins v0.17.1 for Whisper + bitsandbytes 4-bit; turbo + short max_len is a typical VRAM-friendly setup.
TRANSCRIBE_VLLM_MODEL=openai/whisper-large-v3-turbo
TRANSCRIBE_VLLM_SERVED_MODEL_NAME=whisper-large-v3-turbo
TRANSCRIBE_VLLM_TOKENIZER=openai/whisper-large-v3-turbo
TRANSCRIBE_VLLM_TENSOR_PARALLEL_SIZE=1
TRANSCRIBE_VLLM_GPU_MEMORY_UTILIZATION=0.2
TRANSCRIBE_VLLM_MAX_MODEL_LEN=448
TRANSCRIBE_VLLM_TRUST_REMOTE_CODE=1
# Example (v0.17.x): add --swap-space 8 inside the quotes if you need KV headroom
TRANSCRIBE_VLLM_EXTRA_ARGS="--quantization bitsandbytes --load-format bitsandbytes --dtype float16 --model-loader-extra-config '{\"load_in_4bit\":true,\"bnb_4bit_compute_dtype\":\"float16\",\"bnb_4bit_quant_type\":\"nf4\",\"bnb_4bit_use_double_quant\":true}'"

# App Reranker (self-hosted via vLLM /v1/rerank)
APP_RERANK_PROVIDER=auto
APP_RERANK_BASE_URL=http://vllm_rerank:8000/v1
APP_RERANK_API_KEY=EMPTY
APP_RERANK_MODEL=Qwen/Qwen3-VL-Reranker-2B
APP_RERANK_TIMEOUT_SECONDS=3
APP_RERANK_VLLM_MODEL=Qwen/Qwen3-VL-Reranker-2B
APP_RERANK_TOKENIZER=Qwen/Qwen3-VL-Reranker-2B
APP_RERANK_VLLM_TRUST_REMOTE_CODE=1
APP_RERANK_TENSOR_PARALLEL_SIZE=1
# vLLM startup check: free_vram must be >= this fraction * total_vram. On a shared GPU (chat+embed+rerank),
# lower this (e.g. 0.06–0.08) if you see "Free memory ... is less than desired GPU memory utilization".
APP_RERANK_GPU_MEMORY_UTILIZATION=0.08
APP_RERANK_MAX_MODEL_LEN=1024
APP_RERANK_DOC_CHAR_LIMIT=900
# Qwen3-VL reranker: pooling runner + jinja in deploy/docker/vllm/chat_templates.
# Use fp16 only on vLLM 0.17.x — bitsandbytes breaks classifier weight load for this seq-class head (shape mismatch).
APP_RERANK_VLLM_EXTRA_ARGS="--runner pooling --dtype float16 --chat-template /templates/qwen3_vl_reranker.jinja --hf-overrides '{\"architectures\":[\"Qwen3VLForSequenceClassification\"],\"classifier_from_token\":[\"no\",\"yes\"],\"is_original_qwen3_reranker\":true}'"

# Unified multi-format file ingestion limits
INGEST_MAX_FILES=50
INGEST_MAX_FILE_BYTES=52428800
INGEST_ARCHIVE_MAX_FILES=100
INGEST_ARCHIVE_MAX_TOTAL_BYTES=52428800
# Media transcription provider for uploaded audio/video
# Set to "openai" to enable transcription via OpenAI-compatible endpoint.
INGEST_TRANSCRIBE_PROVIDER=openai
# Must match TRANSCRIBE_VLLM_SERVED_MODEL_NAME when using local vLLM transcribe.
INGEST_TRANSCRIBE_MODEL=whisper-large-v3-turbo
INGEST_TRANSCRIBE_OPENAI_BASE_URL=http://vllm_transcribe:8000/v1
INGEST_TRANSCRIBE_OPENAI_API_KEY=EMPTY
# OCR provider for image ingestion/handwritten notes:
# auto (default): Qwen vision first, then local tesseract, then Gemini fallback
# qwen: main local vLLM model OCR only
# local: local tesseract only
# gemini: Gemini OCR only
APP_OCR_PROVIDER=auto
# Optional overrides for qwen OCR provider (defaults to vllm_ocr service values)
APP_OCR_QWEN_BASE_URL=http://vllm_ocr:8000/v1
APP_OCR_QWEN_API_KEY=EMPTY
APP_OCR_QWEN_MODEL=qwen3.5-ocr
APP_OCR_QWEN_TIMEOUT_SECONDS=120

# Memory backend configuration
# local: AquiLLM pgvector memory tables only
# mem0: Mem0 + Qdrant (Compose service names below)
MEMORY_BACKEND=mem0
EPISODIC_TOP_K=3
# Max characters per injected episodic memory line (keeps prompts compact on new chats)
EPISODIC_MEMORY_MAX_CHARS=220
# Optional (unused in OSS-only memory mode; keep blank unless separately using Mem0 cloud APIs).
MEM0_API_KEY=
MEM0_DUAL_WRITE_LOCAL=1
# Timeout used for Mem0 helper calls (fact extraction, OSS search/add retries).
MEM0_TIMEOUT_SECONDS=30
MEM0_LLM_PROVIDER=openai
MEM0_EMBED_PROVIDER=openai
# Compose (all services in stack): use Docker DNS names. For vLLM-on-host dev, use http://host.docker.internal:8000/v1
MEM0_VLLM_BASE_URL=http://vllm:8000/v1
MEM0_LLM_BASE_URL=http://vllm:8000/v1
MEM0_LLM_API_KEY=EMPTY
# OpenAI API model name — must match what vLLM exposes (see VLLM_SERVED_MODEL_NAME).
MEM0_LLM_MODEL=qwen3.5:27b-q8_0
MEM0_LLM_VLLM_MODEL=Qwen/Qwen2.5-32B-Instruct
MEM0_LLM_VLLM_TRUST_REMOTE_CODE=1
MEM0_LLM_TENSOR_PARALLEL_SIZE=1
# Mem0 calls the shared chat vLLM over HTTP; no second GPU process — keep 0.
MEM0_LLM_GPU_MEMORY_UTILIZATION=0
MEM0_LLM_MAX_MODEL_LEN=12288
MEM0_LLM_VLLM_EXTRA_ARGS=
MEM0_EMBED_BASE_URL=http://vllm_embed:8000/v1
MEM0_EMBED_API_KEY=EMPTY
MEM0_EMBED_MODEL=Qwen/Qwen3-VL-Embedding-2B
MEM0_EMBED_VLLM_MODEL=Qwen/Qwen3-VL-Embedding-2B
MEM0_EMBED_TOKENIZER=Qwen/Qwen3-VL-Embedding-2B
MEM0_EMBED_VLLM_TRUST_REMOTE_CODE=1
MEM0_EMBED_TENSOR_PARALLEL_SIZE=1
MEM0_EMBED_GPU_MEMORY_UTILIZATION=0.12
MEM0_EMBED_MAX_MODEL_LEN=2048
MEM0_EMBED_VLLM_EXTRA_ARGS="--quantization bitsandbytes --load-format bitsandbytes --dtype float16 --model-loader-extra-config '{\"load_in_4bit\":true,\"bnb_4bit_compute_dtype\":\"float16\",\"bnb_4bit_quant_type\":\"nf4\",\"bnb_4bit_use_double_quant\":true}'"
MEM0_QDRANT_HOST=qdrant
MEM0_QDRANT_PORT=6333
# Host mounts for Mem0 data stores (use large disks in dev/prod compose).
# Example: /media/volume/aquillmdev2-vol/mem0/qdrant
MEM0_QDRANT_DATA_HOST_PATH=/media/volume/aquillmdev2-vol/mem0/qdrant
# Example: /media/volume/aquillmdev2-vol/mem0/memgraph
MEM0_MEMGRAPH_DATA_HOST_PATH=/media/volume/aquillmdev2-vol/mem0/memgraph
# Pin Memgraph image for deploy stability; Memgraph docs recommend the MAGE image by default.
MEM0_MEMGRAPH_IMAGE=memgraph/memgraph-mage:3.8.1
# Use a fresh collection name when embed model/dims change.
MEM0_COLLECTION_NAME=mem0_vl2b_v1
# Leave blank to infer from the embedder when using VL 2B; set explicitly if you know the width.
MEM0_EMBED_DIMS=
# Optional Mem0 graph memory (OSS + Memgraph; disabled by default)
MEM0_GRAPH_ENABLED=0
MEM0_GRAPH_PROVIDER=memgraph
MEM0_GRAPH_URL=bolt://memgraph:7687
MEM0_GRAPH_USERNAME=memgraph
MEM0_GRAPH_PASSWORD=your-password
MEM0_GRAPH_DATABASE=
MEM0_GRAPH_CUSTOM_PROMPT=
MEM0_GRAPH_THRESHOLD=
MEM0_GRAPH_FAIL_OPEN=1
MEM0_GRAPH_ADD_ENABLED=1
MEM0_GRAPH_SEARCH_ENABLED=1

# OpenAI-compatible chat role for system instructions.
# For local vLLM backends, "system" is generally more reliable than "developer".
OPENAI_SYSTEM_ROLE=system
OPENAI_TOOL_STRICT=1
OPENAI_TEMPERATURE=0.2
OPENAI_TOP_P=0.95
OPENAI_REQUEST_TIMEOUT_SECONDS=180
OPENAI_REQUEST_TIMEOUT_MAX_SECONDS=420
OPENAI_CONTEXT_OVERFLOW_RETRIES=4
OPENAI_TIMEOUT_RETRIES=2
OPENAI_CONTEXT_GUARD_TOKENS=512
OPENAI_ESTIMATOR_PAD_TOKENS=256
# Extra prompt budget reserved for OpenAI-compatible local backends (vLLM, etc.): GPT-4o
# token estimates often undershoot Qwen tokenization near the context ceiling.
OPENAI_COMPAT_PROMPT_SLACK_TOKENS=256
LLM_ALLOW_EXTRACTIVE_FALLBACK=0
LLM_REPEAT_TOOL_BREAK_THRESHOLD=3
LLM_MAX_CALLS_PER_TOOL_NAME=2
# Optional per-tool overrides. Example: vector_search:4,whole_document:2
LLM_TOOL_CALL_LIMITS=
# Break after this many consecutive no-progress tool events (exceptions/repeated outcomes).
LLM_TOOL_NO_PROGRESS_BREAK_THRESHOLD=2
# Optional weighted tool-call budget (disabled when empty).
LLM_TOOL_BUDGET_UNITS_PER_TURN=
# Optional per-tool unit costs when weighted budget is enabled. Example: vector_search:1,whole_document:2
LLM_TOOL_COST_WEIGHTS=
LLM_MIN_COMPLETION_TOKENS=256
LLM_TOOL_MIN_COMPLETION_TOKENS=128
LLM_TOOL_STEP_MAX_TOKENS=512
LLM_POST_TOOL_MAX_TOKENS=1536
LLM_CONTINUATION_MAX_TOKENS=768
LLM_CITATION_RETRY_PRIOR_MAX_CHARS=2400
CHAT_MAX_FUNC_CALLS=6
CHAT_MAX_TOKENS=2048
TOOL_CHUNK_CHAR_LIMIT=1000

# Django default cache — use Redis in Compose so RAG caches survive process restarts and work with multiple web workers.
DJANGO_CACHE_REDIS_URL=redis://redis:6379/1
DJANGO_CACHE_KEY_PREFIX=aquillm

# RAG retrieval caches (short TTLs — fail-open on backend errors)
RAG_CACHE_ENABLED=1
RAG_QUERY_EMBED_TTL_SECONDS=300
RAG_DOC_ACCESS_TTL_SECONDS=60
RAG_IMAGE_DATA_URL_TTL_SECONDS=120
RAG_RERANK_RESULT_TTL_SECONDS=45
RAG_RERANK_CAPABILITY_TTL_SECONDS=900

# Cross-provider prompt preflight trim (Claude/Gemini; uses tiktoken estimate + OpenAI-style trim)
TOKEN_EFFICIENCY_ENABLED=1
PROMPT_BUDGET_CONTEXT_LIMIT=0
PROMPT_BUDGET_MAX_TOKENS_CAP=8192
PROMPT_BUDGET_SLACK_TOKENS=384
PROMPT_COMPRESS_MIN_CHARS=4000
PROMPT_COMPRESS_TARGET_TOKENS=2048

# Salience-aware context packing (runs before cross-provider preflight trim; fail-open on errors)
CONTEXT_PACKER_ENABLED=0
CONTEXT_BUDGET_HISTORY_TOKENS=12000
CONTEXT_BUDGET_TOOL_EVIDENCE_TOKENS=1400
CONTEXT_BUDGET_RETRIEVAL_TOKENS=3500
CONTEXT_PIN_LAST_TURNS=2
CONTEXT_MAX_SNIPPETS_PER_DOC=3
# Optional: shorter keys in vector_search tool JSON (r,i,d,c,n,x,u,ty). Default off.
TOOL_SEARCH_COMPACT_PAYLOAD=0

# Rollout profiles (see docs/superpowers/plans/2026-03-24-context-trimming-rollout-checklist.md):
# Profile A baseline: CONTEXT_PACKER_ENABLED=0
# Profile B smart packer: CONTEXT_PACKER_ENABLED=1

# Web Hugging Face disk cache (LM-Lingua2 / transformers). development.yml bind-mount; default ../../data/hf_web if unset.
# WEB_HF_CACHE_HOST_PATH=/media/volume/your-vol/huggingface-web
# After cache is warm: HF_HUB_OFFLINE=1 and TRANSFORMERS_OFFLINE=1 (blocks new Hub pulls until unset)

# LM-Lingua2 (requires llmlingua in web image; OpenAI-shaped chat path only; fail-open on errors)
# Adapter uses cuda if torch sees a GPU, else cpu — explicit cpu avoids surprises in GPU-less web containers.
LM_LINGUA2_ENABLED=1
LM_LINGUA2_MODEL=microsoft/llmlingua-2-xlm-roberta-large-meetingbank
LM_LINGUA2_DEVICE_MAP=cpu

# vLLM LMCache / KV connector (optional; parsed like VLLM_EXTRA_ARGS when LMCACHE_ENABLED=1)
LMCACHE_ENABLED=0
# Verify flags on YOUR image: docker compose run --rm vllm python3 -m vllm.entrypoints.openai.api_server --help | grep -iE 'kv|offload|lmcache'
# LMCACHE_EXTRA_ARGS="--kv-offloading-backend lmcache --kv-offloading-size 4"

# RAG retrieval tuning (optional)
VECTOR_TOP_K=12
TRIGRAM_TOP_K=12
CHUNK_SIZE=2048
CHUNK_OVERLAP=384
# Hybrid search fan-out: multiplier × short/long query scale, capped by VECTOR/TRIGRAM_TOP_K; mins are floors
RAG_CANDIDATE_MULTIPLIER=3
RAG_VECTOR_MIN_LIMIT=0
RAG_TRIGRAM_MIN_LIMIT=0
RAG_TRIGRAM_SIMILARITY_MIN=0.000001
RAG_QUERY_SHORT_LEN=48
RAG_QUERY_LONG_LEN=160
RAG_SHORT_QUERY_CANDIDATE_SCALE=0.9
RAG_LONG_QUERY_CANDIDATE_SCALE=1.1
APP_RAG_ENABLE_IMAGE_CHUNKS=1

# Zotero Integration (Optional)
# Register your app at https://www.zotero.org/oauth/apps as a "Browser application"
# Callback URL for localhost: http://localhost:8080/zotero/callback/
# Callback URL for production: https://yourdomain.com/zotero/callback/
ZOTERO_CLIENT_KEY=your-zotero-client-key
ZOTERO_CLIENT_SECRET=your-zotero-client-secret

