# Main Qwen3.6 service image with Genesis runtime patches.
#
# Keep this separate from Dockerfile: Whisper/embed/rerank sidecars should stay
# on the plain vLLM image unless they explicitly need Genesis.
ARG VLLM_GENESIS_BASE_IMAGE=vllm/vllm-openai:v0.21.0
FROM ${VLLM_GENESIS_BASE_IMAGE}

ARG GENESIS_REF=main

USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends git libsndfile1 \
    && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir soundfile

RUN git clone --depth 1 --branch "${GENESIS_REF}" \
        https://github.com/Sandermage/genesis-vllm-patches.git /tmp/genesis \
    && cd /tmp/genesis \
    && pip install --no-deps --no-cache-dir ./genesis_vllm_plugin \
    && VLLM_DIR="$(python3 -c 'import os, vllm; print(os.path.dirname(vllm.__file__))')" \
    && cp -r vllm/_genesis "${VLLM_DIR}/_genesis" \
    && rm -rf /tmp/genesis

COPY --chmod=755 ./deploy/scripts/vllm_start.sh /vllm_start.sh
COPY --chmod=755 ./deploy/scripts/genesis_vllm_entrypoint.sh /genesis_entrypoint.sh
COPY --chmod=755 ./deploy/scripts/parse_vllm_extra_args.py /parse_vllm_extra_args.py
COPY ./deploy/docker/vllm/chat_templates /templates

EXPOSE 8000
ENTRYPOINT ["/genesis_entrypoint.sh"]
