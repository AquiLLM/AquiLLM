{
  "id": null,
  "uid": "aquillm-runtime-overview",
  "title": "AquiLLM Runtime Overview",
  "description": "Runtime observability for the AquiLLM platform",
  "editable": true,
  "schemaVersion": 39,
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(django_http_requests_total_by_method_total[5m])",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Chunk Search Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, rate(aquillm_chunk_search_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(aquillm_chunk_search_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, rate(aquillm_chunk_search_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "title": "RAG Cache Hit Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(aquillm_rag_cache_ops_total{result=\"hit\"}[5m]) / (rate(aquillm_rag_cache_ops_total{result=\"hit\"}[5m]) + rate(aquillm_rag_cache_ops_total{result=\"miss\"}[5m]))",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "id": 6,
      "title": "Context Pack Token Delta",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "aquillm_context_pack_tokens",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Ingestion Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(aquillm_ingestion_items_total[5m])",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Chat Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, rate(aquillm_chat_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 {{phase}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(aquillm_chat_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 {{phase}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, rate(aquillm_chat_latency_seconds_bucket[5m]))",
          "legendFormat": "p99 {{phase}}"
        }
      ]
    }
  ]
}
